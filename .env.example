# DeepSeek API Key
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 抓取回溯天数（默认1天，首次运行可设为3）
LOOKBACK_DAYS=1

# Feishu (optional) — sender/send_feishu.py
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_RECEIVE_ID=
# FEISHU_RECEIVE_ID_TYPE=user_id
# FEISHU_MESSAGE=
# FEISHU_MSG_FORMAT=auto
# FEISHU_POST_TITLE=
# FEISHU_MAX_CHARS=8000
# FEISHU_POST_MD_MAX_CHARS=28000
# FEISHU_RAW_ANGLE_BRACKETS=0
# FEISHU_SKIP_FLATTEN=0
